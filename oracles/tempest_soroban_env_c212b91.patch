+// ---- TEMPEST auth oracle: AX-03 classic-account auth always checks MEDIUM ----
+// Executed ground-truth: a classic G... account authorizes any Soroban require_auth at
+// the MEDIUM threshold; there is no path to the HIGH threshold. A treasury that assumes
+// its high-threshold signer policy protects large token transfers is only med-protected.
+#[test]
+fn tempest_ax03_classic_auth_always_medium() {
+    use crate::builtin_contracts::account_contract::check_account_authentication;
+    use crate::builtin_contracts::testutils::{
+        create_account, generate_signing_key, sign_payload_for_account, signing_key_to_account_id,
+    };
+    use soroban_env_common::{EnvBase, TryIntoVal, Val};
+
+    let host = Host::test_host_with_recording_footprint();
+    host.set_base_prng_seed([0u8; 32]).unwrap();
+
+    let payload_bytes = [7u8; 32];
+
+    // helper: account identity is a DISTINCT key (master_weight 0); `signer` is an
+    // additional signer whose weight we control. thresholds = [master, low, MED, HIGH].
+    let authenticate = |signer_weight: u32| -> Result<(), HostError> {
+        let account_key = generate_signing_key(&host); // master (weight 0), unused for signing
+        let signer = generate_signing_key(&host);      // additional signer
+        let account_id = signing_key_to_account_id(&account_key);
+        create_account(
+            &host, &account_id, &[(&signer, signer_weight)],
+            100_000_000, 0, [0, 1, 10, 20], None, None, 0,
+        );
+        let payload = host.bytes_new_from_slice(&payload_bytes).unwrap();
+        let sig = sign_payload_for_account(&host, &signer, &payload_bytes);
+        let sig_val: Val = sig.try_into_val(&host).unwrap();
+        let sigs = host.vec_new_from_slice(&[sig_val]).unwrap();
+        check_account_authentication(&host, account_id, payload, sigs.to_val())
+    };
+
+    let res_med = authenticate(10);  // == MED (10), < HIGH (20)
+    let res_below = authenticate(9); // < MED
+
+    println!("\n=== TEMPEST auth oracle [AX-03 classic always-MEDIUM] ===");
+    println!("account thresholds [master,low,MED,HIGH] = [0,1,10,20]");
+    println!("weight 10 (== MED, < HIGH) authorizes: {}   res={:?}", res_med.is_ok(), res_med);
+    println!("weight 9  (< MED) rejected:            {}", res_below.is_err());
+    assert!(res_med.is_ok(), "AX-03: weight==MED must authorize a Soroban op");
+    assert!(res_below.is_err(), "control: weight<MED must be rejected");
+    println!("AX-03 CONFIRMED (executed): Soroban classic-account auth authorizes at MEDIUM; HIGH (20) is unreachable — a high-threshold treasury is only med-protected for Soroban ops");
+}
